{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pre-edit-hook.sh'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/post-edit-hook.sh'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/stop-hook.sh'"
          }
        ]
      }
    ]
  }
}
